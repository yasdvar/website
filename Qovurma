<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Qovurma — Traditional Azerbaijani Restaurant</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #F5EFE0;
    --warm-white: #FAF6EE;
    --dark: #1C1409;
    --brown: #4A2E0E;
    --gold: #C49A3C;
    --gold-light: #E8C97A;
    --terra: #A0431F;
    --muted: #7A6850;
    --border: rgba(196,154,60,0.25);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Jost', sans-serif;
    background: var(--dark);
    color: var(--cream);
    overflow-x: hidden;
  }

  /* --- NAV --- */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.5rem 3rem;
    background: linear-gradient(to bottom, rgba(28,20,9,0.95), transparent);
    backdrop-filter: blur(4px);
  }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--gold);
    text-decoration: none;
  }

  .nav-links {
    display: flex; gap: 2.5rem; list-style: none;
  }

  .nav-links a {
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cream);
    text-decoration: none;
    opacity: 0.75;
    transition: opacity 0.2s;
  }

  .nav-links a:hover { opacity: 1; color: var(--gold-light); }

  .nav-cta {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--dark);
    background: var(--gold);
    padding: 0.6rem 1.4rem;
    text-decoration: none;
    transition: background 0.2s;
  }

  .nav-cta:hover { background: var(--gold-light); }

  /* --- HERO --- */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8rem 4rem 6rem 5rem;
    position: relative;
    z-index: 2;
  }

  .hero-eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.3s forwards;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.5rem, 6vw, 5.5rem);
    font-weight: 300;
    line-height: 1.05;
    color: var(--cream);
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.5s forwards;
  }

  .hero-title em {
    font-style: italic;
    color: var(--gold-light);
  }

  .hero-desc {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--muted);
    max-width: 380px;
    margin-bottom: 3rem;
    font-weight: 300;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.7s forwards;
  }

  .hero-actions {
    display: flex; gap: 1.2rem; align-items: center;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.9s forwards;
  }

  .btn-primary {
    display: inline-block;
    background: var(--gold);
    color: var(--dark);
    padding: 1rem 2.2rem;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    transition: background 0.2s, transform 0.2s;
  }

  .btn-primary:hover { background: var(--gold-light); transform: translateY(-1px); }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cream);
    text-decoration: none;
    opacity: 0.65;
    transition: opacity 0.2s;
  }

  .btn-ghost:hover { opacity: 1; }

  .hero-image {
    position: relative;
    overflow: hidden;
  }

  .hero-image::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to right, var(--dark) 0%, transparent 30%);
    z-index: 1;
  }

  .hero-image img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: sepia(20%) brightness(0.75);
  }

  .hero-image-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #2A1A08 0%, #3D2410 40%, #1C1409 100%);
    display: flex; align-items: center; justify-content: center;
  }

  .hero-pattern {
    opacity: 0.08;
    width: 100%; height: 100%;
    background-image: 
      repeating-linear-gradient(45deg, var(--gold) 0, var(--gold) 1px, transparent 0, transparent 50%),
      repeating-linear-gradient(-45deg, var(--gold) 0, var(--gold) 1px, transparent 0, transparent 50%);
    background-size: 40px 40px;
  }

  .hero-badge {
    position: absolute; bottom: 3rem; left: 3rem; z-index: 2;
    display: flex; align-items: center; gap: 1rem;
    background: rgba(28,20,9,0.85);
    border: 0.5px solid var(--border);
    padding: 1rem 1.5rem;
    backdrop-filter: blur(8px);
    opacity: 0;
    animation: fadeUp 0.8s ease 1.1s forwards;
  }

  .badge-stars { color: var(--gold); font-size: 0.85rem; letter-spacing: 2px; }
  .badge-text { font-size: 0.75rem; color: var(--muted); line-height: 1.5; }
  .badge-number { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 300; color: var(--gold); }

  /* --- SECTION COMMONS --- */
  .section { padding: 7rem 5rem; }
  .section-label {
    font-size: 0.72rem; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1rem;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--cream);
    margin-bottom: 1.5rem;
  }
  .section-title em { font-style: italic; color: var(--gold-light); }

  /* --- ABOUT --- */
  .about {
    display: grid; grid-template-columns: 1fr 1fr; gap: 6rem;
    padding: 7rem 5rem;
    border-top: 0.5px solid var(--border);
  }

  .about-text p {
    font-size: 0.95rem; line-height: 1.9;
    color: var(--muted); font-weight: 300; margin-bottom: 1rem;
  }

  .about-stats {
    display: flex; flex-direction: column; justify-content: center; gap: 3rem;
  }

  .stat {
    border-left: 1px solid var(--gold);
    padding-left: 1.5rem;
  }

  .stat-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem; font-weight: 300; color: var(--gold);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.75rem; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--muted);
    margin-top: 0.3rem;
  }

  /* --- MENU --- */
  .menu-section {
    padding: 7rem 5rem;
    background: var(--warm-white);
    color: var(--dark);
    border-top: 0.5px solid var(--border);
  }

  .menu-section .section-label { color: var(--terra); }
  .menu-section .section-title { color: var(--dark); }
  .menu-section .section-title em { color: var(--terra); }

  .menu-tabs {
    display: flex; gap: 0; margin: 3rem 0 2rem;
    border-bottom: 1px solid rgba(74,46,14,0.15);
  }

  .tab-btn {
    background: none; border: none;
    padding: 0.8rem 1.8rem;
    font-family: 'Jost', sans-serif;
    font-size: 0.78rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--muted); cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: all 0.2s;
  }

  .tab-btn.active {
    color: var(--brown);
    border-bottom-color: var(--terra);
  }

  .menu-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0;
  }

  .menu-item {
    display: flex; justify-content: space-between; align-items: flex-start;
    padding: 1.4rem 0;
    border-bottom: 0.5px solid rgba(74,46,14,0.1);
    gap: 1rem;
  }

  .menu-item:nth-child(odd) { padding-right: 3rem; }
  .menu-item:nth-child(even) { padding-left: 3rem; border-left: 0.5px solid rgba(74,46,14,0.1); }

  .menu-item-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; font-weight: 400; color: var(--brown);
    margin-bottom: 0.25rem;
  }

  .menu-item-desc {
    font-size: 0.78rem; color: var(--muted); line-height: 1.6;
    font-weight: 300;
  }

  .menu-item-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem; font-weight: 300;
    color: var(--terra); white-space: nowrap;
    padding-top: 2px;
  }

  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* --- INFO STRIP --- */
  .info-strip {
    display: grid; grid-template-columns: repeat(3, 1fr);
    border-top: 0.5px solid var(--border);
  }

  .info-card {
    padding: 3.5rem 3rem;
    border-right: 0.5px solid var(--border);
  }

  .info-card:last-child { border-right: none; }

  .info-icon {
    width: 36px; height: 36px;
    border: 0.5px solid var(--gold);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.5rem;
    font-size: 14px; color: var(--gold);
  }

  .info-card-title {
    font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 0.8rem;
  }

  .info-card-content {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.05rem; font-weight: 300;
    color: var(--cream); line-height: 1.9;
  }

  .info-card-content a {
    color: var(--gold-light); text-decoration: none;
    border-bottom: 0.5px solid var(--border);
  }

  /* --- GALLERY --- */
  .gallery {
    display: grid; grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: 300px 300px;
    gap: 2px;
    height: 602px;
  }

  .gallery-item {
    overflow: hidden; position: relative;
    background: var(--brown);
  }

  .gallery-item:first-child { grid-row: 1 / 3; }

  .gallery-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.85rem; letter-spacing: 0.1em;
    color: rgba(196,154,60,0.3);
  }

  .gallery-item:nth-child(1) .gallery-placeholder { font-size: 1rem; }

  .gp1 { background: linear-gradient(135deg, #2D1A08, #4A2E0E); }
  .gp2 { background: linear-gradient(225deg, #1C1409, #3A200A); }
  .gp3 { background: linear-gradient(45deg, #3A2010, #5A3015); }
  .gp4 { background: linear-gradient(135deg, #251505, #3D2008); }
  .gp5 { background: linear-gradient(315deg, #2A1808, #482A10); }

  /* --- RESERVATION --- */
  .reservation {
    padding: 7rem 5rem;
    display: grid; grid-template-columns: 1fr 1fr; gap: 6rem;
    border-top: 0.5px solid var(--border);
  }

  .res-form { display: flex; flex-direction: column; gap: 1rem; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }

  .form-label {
    font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--muted);
  }

  .form-input, .form-select, .form-textarea {
    background: transparent;
    border: 0.5px solid rgba(196,154,60,0.3);
    color: var(--cream);
    padding: 0.85rem 1rem;
    font-family: 'Jost', sans-serif;
    font-size: 0.9rem; font-weight: 300;
    outline: none;
    transition: border-color 0.2s;
    -webkit-appearance: none;
  }

  .form-input:focus, .form-select:focus, .form-textarea:focus {
    border-color: var(--gold);
  }

  .form-select option { background: var(--dark); color: var(--cream); }

  .form-textarea { resize: vertical; min-height: 80px; }

  .form-submit {
    background: var(--gold); color: var(--dark);
    border: none; padding: 1.1rem;
    font-family: 'Jost', sans-serif;
    font-size: 0.78rem; letter-spacing: 0.2em; text-transform: uppercase;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 0.5rem;
  }

  .form-submit:hover { background: var(--gold-light); }

  /* --- FOOTER --- */
  footer {
    padding: 3rem 5rem;
    border-top: 0.5px solid var(--border);
    display: flex; justify-content: space-between; align-items: center;
  }

  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem; color: var(--gold); font-weight: 600; letter-spacing: 0.08em;
  }

  .footer-text {
    font-size: 0.75rem; color: var(--muted); letter-spacing: 0.05em;
  }

  .footer-contact {
    text-align: right; font-size: 0.8rem; color: var(--muted); line-height: 1.7;
  }

  .footer-contact a { color: var(--gold-light); text-decoration: none; }

  /* --- ANIMATIONS --- */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .reveal {
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* --- ORNAMENT --- */
  .ornament {
    width: 60px; height: 1px;
    background: linear-gradient(to right, transparent, var(--gold), transparent);
    margin: 2rem 0;
  }

  .ornament-center { margin: 2rem auto; }

  /* scroll divider */
  .scroll-line {
    position: absolute; bottom: 2.5rem; left: 5rem;
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--muted); z-index: 2;
    opacity: 0; animation: fadeUp 0.8s ease 1.3s forwards;
  }

  .scroll-line::after {
    content: '';
    width: 1px; height: 50px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    display: block;
  }

</style>
</head>
